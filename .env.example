# Google Generative AI (Gemini)
GOOGLE_API_KEY=seu_google_api_key_aqui

# Groq API (fallback para geração de questões)
GROQ_API_KEY=seu_groq_api_key_aqui

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aws_simulator
DB_USER=postgres
DB_PASSWORD=postgres

# PGlite (required outside NODE_ENV=test)
DB_DATA_DIR=.pglite/aws-simulator
NODE_ENV=development

# FastAPI
API_HOST=localhost
API_PORT=8000

# Express API
PORT=3001

# Configurações opcionais
ENVIRONMENT=development
DEBUG=false
